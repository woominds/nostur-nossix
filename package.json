{
  "name": "nostur-nossix",
  "productName": "NOSTUR",
  "private": true,
  "version": "0.3.1",
  "description": "NOSTUR - Sistema integral de turismo emisivo",
  "author": "NOSTUR",
  "main": "electron/main.cjs",
  "type": "module",
 "scripts": {
  "deploy:nossix": "node scripts/deploy-nossix.mjs",
  "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
  "dev:renderer": "vite --host 127.0.0.1 --port 5173",
  "dev:electron": "wait-on http://127.0.0.1:5173 && electron .",
  "dev:web": "vite --host 0.0.0.0 --port 5173",
  "dev:mobile": "vite --host 0.0.0.0 --port 5173 --mode mobile",
  "build": "tsc -b && vite build",
  "build:web": "tsc -b && vite build --mode mobile",
  "dist": "npm run build && electron-builder",
  "dist:mac": "npm run build && electron-builder --mac",
  "dist:win": "npm run build && electron-builder --win",
  "preview": "vite preview",
  "preview:web": "vite preview --host 0.0.0.0 --port 4173",
  "typecheck": "tsc --noEmit",
  "lint": "eslint .",
  "import:live-html": "tsx scripts/importarLiveConnectHtml.ts",
  "deploy:pwa:nossix": "npm run build:web && node scripts/deploy-pwa-nossix.mjs",
  "deploy:desktop:mac:nossix": "npm run dist:mac && node scripts/deploy-desktop-nossix.mjs mac",
  "deploy:desktop:win:nossix": "npm run dist:win && node scripts/deploy-desktop-nossix.mjs win",
  "deploy:desktop:all:nossix": "node scripts/deploy-desktop-nossix.mjs mac && node scripts/deploy-desktop-nossix.mjs win"
},
  "build": {
    "appId": "com.nostur.nossix",
    "productName": "NOSTUR",
    "executableName": "NOSTUR",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": [
          "icon.icns",
          "icon.ico",
          "icon.png"
        ]
      }
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://nossix.nostur.com.ar/desktop/${os}"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "NOSTUR-NOSSIX-${version}-${arch}-mac.${ext}"
    },
    "dmg": {
      "title": "NOSTUR",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "NOSTUR-NOSSIX-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NOSTUR",
      "artifactName": "NOSTUR-NOSSIX-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@supabase/supabase-js": "^2.105.3",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}
