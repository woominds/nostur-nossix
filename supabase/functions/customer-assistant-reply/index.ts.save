// @ts-nocheck

/* =========================================================
   NOSSIX / NOSTUR — customer-assistant-reply
   IAPAX · Asistente de Pasajeros

   Recibe:
   - conversation_id
   - inbound_message_id
   - force
   - source
   - mode

   Hace:
   - lee conversación
   - lee últimos mensajes
   - lee configuración de IAPAX desde ai_personas
   - genera respuesta con OpenAI si hay OPENAI_API_KEY
   - si no hay OPENAI_API_KEY usa fallback comercial
   - guarda mensaje outbound
   - envía por WhatsApp usando whatsapp-send-message
========================================================= */

import { serve } from "https://deno.land/std@0.168.0/http/server.ts";
import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
  "Access-Control-Allow-Methods": "GET, POST, OPTIONS"
};

/* =========================================================
   RESPONSES
========================================================= */

function jsonResponse(body: Record<string, unknown>, status = 200): Response {
  return new Response(JSON.stringify(body), {
    status,
    headers: {
      ...corsHeaders,
      "Content-Type": "application/json"
    }
  });
}

/* =========================================================
   CLIENTS / ENV
========================================================= */

function getSupabaseAdmin() {
  const supabaseUrl =
    Deno.env.get("SUPABASE_URL") ||
    "https://vkzgfhdfqyjqwvowtarh.supabase.co";

  const serviceRoleKey =
    Deno.env.get("NOSTUR_SERVICE_ROLE_KEY") ||
    Deno.env.get("SUPABASE_SERVICE_ROLE_KEY");

  if (!serviceRoleKey) {
    throw new Error("Falta configurar NOSTUR_SERVICE_ROLE_KEY o SUPABASE_SERVICE_ROLE_KEY.");
  }

  return createClient(supabaseUrl, serviceRoleKey, {
    auth: {
      persistSession: false,
      autoRefreshToken: false
    }
  });
}

/* =========================================================
   HELPERS
========================================================= */

function cleanText(value: unknown): string {
  return String(value || "").trim();
}

function normalizePhoneToPlus(value: unknown): string {
  const raw = String(value || "").replace(/[^\d+]/g, "");

  if (!raw) return "";
  if (raw.startsWith("+")) return raw;

  return `+${raw}`;
}

function readRecord(value: unknown): Record<string, unknown> {
  if (!value || typeof value !== "object" || Array.isArray(value)) return {};
  return value as Record<string, unknown>;
}

function readStringArray(value: unknown): string[] {
  if (!Array.isArray(value)) return [];

  return value
    .map((item) => String(item || "").trim())
    .filter(Boolean);
}

function getNowIso(): string {
  return new Date().toISOString();
}

function isConversationAutomatic(conversation: any): boolean {
  const enabled = Boolean(conversation?.customer_ai_enabled);
  const mode = cleanText(conversation?.customer_ai_mode).toUpperCase();
  const status = cleanText(conversation?.customer_ai_status).toUpperCase();
  const handoffStatus = cleanText(conversation?.customer_ai_handoff_status).toUpperCase();

  if (!enabled) return false;
  if (mode !== "AUTOMATICA") return false;
  if (status === "INACTIVA") return false;
  if (status === "PAUSADA") return false;

  if (handoffStatus === "PENDIENTE_VENDEDOR") return false;
  if (handoffStatus === "DERIVADA") return false;
  if (handoffStatus === "TOMADA") return false;

  return true;
}

function getFallbackReply(params: {
  conversation: any;
  lastInboundText: string;
  personaMetadata: Record<string, unknown>;
}) {
  const fallbackMessage =
    cleanText(params.personaMetadata.fallback_message) ||
    "Hola, gracias por escribirnos. Para poder ayudarte mejor, ¿me indicás destino, fecha aproximada de viaje y cantidad de pasajeros?";

  const text = params.lastInboundText.toLowerCase();

  if (text.includes("hola") || text.includes("buenas") || text.includes("buen día") || text.includes("buen dia")) {
    return (
      cleanText(params.personaMetadata.welcome_message) ||
      "Hola, soy el asistente de NOSSIX Travel. Te ayudo a avanzar con tu consulta para que un asesor pueda cotizarte mejor. ¿A qué destino querés viajar y en qué fecha aproximada?"
    );
  }

  if (text.includes("brasil") || text.includes("punta cana") || text.includes("bayahibe") || text.includes("caribe")) {
    return "¡Genial! Para poder orientarte mejor, ¿me indicás desde qué ciudad saldrían, cuántos pasajeros son y cuántas noches quieren viajar?";
  }

  if (text.includes("diciembre") || text.includes("enero") || text.includes("febrero") || text.includes("noviembre")) {
    return "Perfecto. ¿Cuántos adultos y menores viajan? Si hay menores, pasame también las edades para que podamos cotizar correctamente.";
  }

  return fallbackMessage;
}

async function saveDebug(params: {
  supabase: any;
  eventType: string;
  conversationId?: string | null;
  messageId?: string | null;
  rawPayload: any;
}) {
  try {
    await params.supabase.from("whatsapp_webhook_debug").insert({
      event_type: params.eventType,
      field: "customer-assistant-reply",
      whatsapp_message_id: params.messageId || null,
      raw_payload: {
        conversation_id: params.conversationId || null,
        ...readRecord(params.rawPayload)
      }
    });
  } catch {
    // El debug no debe romper la función.
  }
}

/* =========================================================
   OPENAI
========================================================= */

async function generateAiReply(params: {
  conversation: any;
  messages: any[];
  persona: any;
}) {
  const openAiKey = Deno.env.get("OPENAI_API_KEY");

  const metadata = readRecord(params.persona?.metadata);

  const lastInbound = [...params.messages]
    .reverse()
    .find((message) => message.direction === "inbound");

  const lastInboundText = cleanText(lastInbound?.content);

  if (!openAiKey) {
    return getFallbackReply({
      conversation: params.conversation,
      lastInboundText,
      personaMetadata: metadata
    });
  }

  const canSay = cleanText(metadata.can_say);
  const cannotSay = cleanText(metadata.cannot_say);
  const businessRules = cleanText(metadata.business_rules);
  const handoffRules = cleanText(metadata.handoff_rules);
  const tone = cleanText(params.persona?.tone) || "Amable, comercial, claro y profesional.";

  const conversationText = params.messages
    .slice(-16)
    .map((message) => {
      const who =
        message.direction === "inbound"
          ? "Pasajero"
          : message.direction === "outbound"
            ? "Agente"
            : "Sistema";

      return `${who}: ${cleanText(message.content)}`;
    })
    .join("\n");

  const systemPrompt = [
    "Sos IAPAX, la IA vendedora / primer filtro de NOSSIX Travel.",
    "Tu función es responder consultas iniciales de pasajeros por WhatsApp.",
    "Debés indagar con preguntas simples, de a una o dos por vez, sin saturar.",
    "Objetivo: detectar destino, fecha aproximada, cantidad de pasajeros, edades de menores, ciudad de salida, cantidad de noches, presupuesto y urgencia.",
    "No confirmes disponibilidad final, no garantices precios, no emitas tickets, no tomes pagos y no inventes políticas.",
    "Si detectás urgencia, reclamo, pasajero en destino, problema de documentación, cambios, cancelaciones, pago pendiente o pedido explícito de asesor, respondé brevemente y pedí intervención de un asesor.",
    "",
    `Tono: ${tone}`,
    canSay ? `Puede decir: ${canSay}` : "",
    cannotSay ? `No puede decir: ${cannotSay}` : "",
    businessRules ? `Reglas de negocio: ${businessRules}` : "",
    handoffRules ? `Reglas de derivación: ${handoffRules}` : "",
    "",
    "Respondé SIEMPRE en español argentino.",
    "Respuesta corta, natural y lista para enviar por WhatsApp.",
    "No uses markdown pesado.",
    "No digas que sos ChatGPT."
  ]
    .filter(Boolean)
    .join("\n");

  const userPrompt = [
    "Conversación reciente:",
    conversationText || "Sin mensajes previos.",
    "",
    "Último mensaje del pasajero:",
    lastInboundText || "Sin contenido.",
    "",
    "Generá la próxima respuesta de IAPAX."
  ].join("\n");

  const response = await fetch("https://api.openai.com/v1/responses", {
    method: "POST",
    headers: {
      Authorization: `Bearer ${openAiKey}`,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: Deno.env.get("OPENAI_MODEL_IAPAX") || "gpt-4.1-mini",
      input: [
        {
          role: "system",
          content: systemPrompt
        },
        {
          role: "user",
          content: userPrompt
        }
      ],
      temperature: 0.5,
      max_output_tokens: 260
    })
  });

  const data = await response.json();

  if (!response.ok) {
    throw new Error(data?.error?.message || "OpenAI no pudo generar respuesta.");
  }

  const outputText =
    cleanText(data.output_text) ||
    cleanText(data.output?.[0]?.content?.[0]?.text) ||
    cleanText(data.output?.[0]?.content?.[0]?.content);

  if (!outputText) {
    return getFallbackReply({
      conversation: params.conversation,
      lastInboundText,
      personaMetadata: metadata
    });
  }

  return outputText;
}

/* =========================================================
   MAIN
========================================================= */

serve(async (req) => {
  if (req.method === "OPTIONS") {
    return new Response("ok", {
      headers: corsHeaders
    });
  }

  if (req.method !== "POST") {
    return jsonResponse(
      {
        ok: false,
        error: "Método no permitido."
      },
      405
    );
  }

  const supabase = getSupabaseAdmin();

  try {
    const body = await req.json();

    const conversationId = cleanText(body.conversation_id);
    const inboundMessageId = cleanText(body.inbound_message_id);
    const force = Boolean(body.force);

    if (!conversationId) {
      return jsonResponse(
        {
          ok: false,
          error: "Falta conversation_id."
        },
        400
      );
    }

    await saveDebug({
      supabase,
      eventType: "iapax_request",
      conversationId,
      messageId: inboundMessageId || null,
      rawPayload: body
    });

    const conversationRes = await supabase
      .from("conversations")
      .select("*")
      .eq("id", conversationId)
      .maybeSingle();

    if (conversationRes.error) throw conversationRes.error;

    const conversation = conversationRes.data;

    if (!conversation?.id) {
      return jsonResponse({
        ok: false,
        skipped: true,
        reason: "No se encontró la conversación."
      });
    }

    if (!force && !isConversationAutomatic(conversation)) {
      await saveDebug({
        supabase,
        eventType: "iapax_skipped_not_automatic",
        conversationId,
        messageId: inboundMessageId || null,
        rawPayload: {
          customer_ai_enabled: conversation.customer_ai_enabled,
          customer_ai_mode: conversation.customer_ai_mode,
          customer_ai_status: conversation.customer_ai_status,
          customer_ai_handoff_status: conversation.customer_ai_handoff_status
        }
      });

      return jsonResponse({
        ok: true,
        skipped: true,
        reason: "IAPAX no está en modo automático."
      });
    }

    const personaRes = await supabase
      .from("ai_personas")
      .select("*")
      .eq("code", "customer_assistant")
      .maybeSingle();

    if (personaRes.error) throw personaRes.error;

    const persona = personaRes.data || null;

    const messagesRes = await supabase
      .from("messages")
      .select("*")
      .eq("conversation_id", conversationId)
      .is("deleted_at", null)
      .order("created_at", { ascending: true })
      .limit(40);

    if (messagesRes.error) throw messagesRes.error;

    const messages = messagesRes.data || [];

    const replyText = await generateAiReply({
      conversation,
      messages,
      persona
    });

    if (!replyText) {
      await supabase
        .from("conversations")
        .update({
          customer_ai_last_error: "IAPAX no generó respuesta.",
          updated_at: getNowIso()
        })
        .eq("id", conversationId);

      return jsonResponse({
        ok: false,
        error: "IAPAX no generó respuesta."
      });
    }

    const now = getNowIso();
    const phone = normalizePhoneToPlus(conversation.telefono);

    const insertMessageRes = await supabase
      .from("messages")
      .insert({
        conversation_id: conversationId,
        channel: "whatsapp",
        direction: "outbound",
        sender_type: "agent",
        sender_id: null,
        sender_name: persona?.display_name || "IAPAX · Asistente de Pasajeros",
        content: replyText,
        message_type: "text",
        status: "pending",
        is_internal: false,
        metadata: {
          source: "customer-assistant-reply",
          ai_persona_code: "customer_assistant",
          ai_persona_id: persona?.id || null,
          inbound_message_id: inboundMessageId || null,
          automatic: true
        },
        created_at: now,
        created_by: null
      })
      .select("id")
      .single();

    if (insertMessageRes.error) throw insertMessageRes.error;

    const localMessageId = insertMessageRes.data.id;

    await supabase
      .from("conversations")
      .update({
        last_message: replyText,
        last_message_time: now,
        last_outbound_message_at: now,
        customer_ai_status: "RESPONDIENDO",
        customer_ai_last_response_at: now,
        customer_ai_last_error: null,
        customer_ai_auto_reply_count: Number(conversation.customer_ai_auto_reply_count || 0) + 1,
        updated_at: now
      })
      .eq("id", conversationId);

    if (!phone) {
      await supabase
        .from("messages")
        .update({
          status: "failed",
          wa_error_code: "missing_phone",
          wa_error_message: "La conversación no tiene teléfono."
        })
        .eq("id", localMessageId);

      return jsonResponse({
        ok: false,
        error: "La conversación no tiene teléfono.",
        local_message_id: localMessageId
      });
    }

    const sendRes = await supabase.functions.invoke("whatsapp-send-message", {
      body: {
        conversation_id: conversationId,
        local_message_id: localMessageId,
        to: phone,
        content: replyText,
        text: replyText,
        message_type: "text",
        source: "customer-assistant-reply"
      }
    });

    if (sendRes.error) {
      await supabase
        .from("messages")
        .update({
          status: "failed",
          wa_error_message: sendRes.error.message || "No se pudo enviar WhatsApp."
        })
        .eq("id", localMessageId);

      await supabase
        .from("conversations")
        .update({
          customer_ai_last_error: sendRes.error.message || "No se pudo enviar WhatsApp.",
          updated_at: getNowIso()
        })
        .eq("id", conversationId);

      return jsonResponse({
        ok: false,
        error: sendRes.error.message || "No se pudo enviar WhatsApp.",
        local_message_id: localMessageId
      });
    }

    await saveDebug({
      supabase,
      eventType: "iapax_replied",
      conversationId,
      messageId: inboundMessageId || null,
      rawPayload: {
        local_message_id: localMessageId,
        reply: replyText,
        send_response: sendRes.data || null
      }
    });

    return jsonResponse({
      ok: true,
      replied: true,
      conversation_id: conversationId,
      local_message_id: localMessageId,
      reply: replyText
    });
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);

    try {
      await saveDebug({
        supabase,
        eventType: "iapax_exception",
        rawPayload: {
          error: message
        }
      });
    } catch {
      // Evita error secundario.
    }

    return jsonResponse(
      {
        ok: false,
        error: message
      },
      200
    );
  }
});
